{
    "model": {
        "type": "condition",
        "property": "component",
        "predicate": "custom_data",
        "value": {
            "id": "HYPERION"
        },
        "on_true": {
            "type": "select",
            "property": "display_context",
            "cases": [
                {
                    "model": {
                        "type": "model",
                        "model": "psnprsm:combat/dungeon/weapons/hyperion_inv"
                    },
                    "when": [
                        "gui", "ground", "fixed", "on_shelf"
                    ]
                }
            ],
            "fallback": {
                "type": "condition",
                "property": "selected",
                "on_true": {
                    "type": "condition",
                    "property": "keybind_down",
                    "keybind": "key.use",
                    "on_true": {
                        "type": "model",
                        "model": "psnprsm:combat/dungeon/weapons/hyperion_blocked"
                    },
                    "on_false": {
                        "type": "model",
                        "model": "psnprsm:combat/dungeon/weapons/hyperion"
                    }
                },
                "on_false": {
                    "type": "model",
                    "model": "psnprsm:combat/dungeon/weapons/hyperion"
                }
            }
        },
        "on_false": {
            "type": "condition",
            "property": "component",
            "predicate": "custom_data",
            "value": {
                "id": "CACTUS_KNIFE"
            },
            "on_true": {
                "type": "model",
                "model": "psnprsm:farming/cactus"
            },
            "on_false": {
                "type": "condition",
                "property": "keybind_down",
                "keybind": "key.use",
                "on_true": {
                    "type": "condition",
                    "property": "selected",
                    "on_true": {
                        "type": "model",
                        "model": "psnprsm:sword/iron"
                    },
                    "on_false": {
                        "type": "model",
                        "model": "item/iron_sword"
                    }
                },
                "on_false": {
                    "type": "model",
                    "model": "item/iron_sword"
                }
            }
        }
    }
}

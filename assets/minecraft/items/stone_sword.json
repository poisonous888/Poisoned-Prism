{
    "model": {
        "type": "condition",
        "property": "component",
        "predicate": "custom_data",
        "value": {
            "id": "DARK_CLAYMORE"
        },
        "on_true": {
            "type": "select",
            "property": "display_context",
            "cases": [
                {
                    "model": {
                        "type": "model",
                        "model": "psnprsm:combat/dungeon/weapons/dark_claymore_inv"
                    },
                    "when": [
                        "gui", "ground", "fixed", "on_shelf"
                    ]
                }
            ],
            "fallback": {
                "type": "condition",
                "property": "selected",
                "on_true": {
                    "type": "condition",
                    "property": "keybind_down",
                    "keybind": "key.use",
                    "on_true": {
                        "type": "model",
                        "model": "psnprsm:combat/dungeon/weapons/dark_claymore_blocked"
                    },
                    "on_false": {
                        "type": "model",
                        "model": "psnprsm:combat/dungeon/weapons/dark_claymore"
                    }
                },
                "on_false": {
                    "type": "model",
                    "model": "psnprsm:combat/dungeon/weapons/dark_claymore"
                }
            }
        },
        "on_false": {
            "type": "condition",
            "property": "selected",
            "on_true": {
                "type": "condition",
                "property": "keybind_down",
                "keybind": "key.use",
                "on_true": {
                    "type": "model",
                    "model": "psnprsm:sword/stone"
                },
                "on_false": {
                    "type": "model",
                    "model": "item/stone_sword"
                }
            },
            "on_false": {
                "type": "model",
                "model": "item/stone_sword"
            }
        }
    }
}

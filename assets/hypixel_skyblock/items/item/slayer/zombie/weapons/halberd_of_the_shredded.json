{
    "model": {
        "type": "select",
        "property": "display_context",
        "cases": [
            {
                "model": {
                    "type": "model",
                    "model": "psnprsm:combat/slayer/zombie/falchion/halberd_inv"
                },
                "when": ["gui", "ground", "fixed", "on_shelf"]
            },
            {
                "model": {
                    "type": "model",
                    "model": "psnprsm:combat/slayer/zombie/falchion/halberd"
                },
                "when": ["none"]
            }
        ],
        "fallback": {
            "type":"condition","property":"selected",
            "on_true":{
                "type":"condition","property":"keybind_down","keybind":"key.use",
                "on_true":{"type":"model","model":"psnprsm:combat/slayer/zombie/falchion/halberd_blocked"},
                "on_false":{"type":"model","model":"psnprsm:combat/slayer/zombie/falchion/halberd"}
            },
            "on_false":{"type":"model","model":"psnprsm:combat/slayer/zombie/falchion/halberd"}
        }
    }
}
{
    "model": {
        "type": "select",
        "property": "display_context",
        "cases": [
            {
                "model": {
                    "type": "model",
                    "model": "psnprsm:combat/slayer/enderman/katana/katana_inv"
                },
                "when": ["gui", "ground", "fixed", "on_shelf"]
            }
        ],
        "fallback": {
            "type": "range_dispatch",
            "property": "cooldown",
            "entries": [
                {
                    "threshold": 0.001,
                    "model": {
                        "type": "condition", "property": "selected",
                        "on_true": {
                            "type": "condition", "property": "keybind_down", "keybind": "key.use",
                            "on_true": {"type": "model", "model": "psnprsm:combat/slayer/enderman/katana/katana_ability_blocked"},
                            "on_false": {"type": "model", "model": "psnprsm:combat/slayer/enderman/katana/katana_ability"}
                        },
                        "on_false": {"type": "model", "model": "psnprsm:combat/slayer/enderman/katana/katana_ability"}
                    }
                }
            ],
            "fallback": {
                "type": "condition", "property": "selected",
                "on_true": {
                    "type": "condition", "property": "keybind_down", "keybind": "key.use",
                    "on_true": {"type": "model", "model": "psnprsm:combat/slayer/enderman/katana/katana_blocked"},
                    "on_false": {"type": "model", "model": "psnprsm:combat/slayer/enderman/katana/katana"}
                },
                "on_false": {"type": "model", "model": "psnprsm:combat/slayer/enderman/katana/katana"}
            }
        }
    }
}
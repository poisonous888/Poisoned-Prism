{
    "model":{
        "type":"condition",
            "property":"using_item",
            "on_false":{
                "type":"model",
                "model":"item/bow"
            },
            "on_true":{
                "type": "range_dispatch",
                "property": "use_duration",
                "scale": 0.05,
                "fallback": {"type":"model","model": "item/bow_pulling_0"},
                "entries":[
                    {
                        "threshold": 0.65,
                        "model":{"type": "model","model": "item/bow_pulling_1"}
                    },
                    {
                        "threshold": 0.9,
                        "model": {"type": "model","model": "item/bow_pulling_2"}
                    }
                ]
            }
    }       
}
